          <div class="week-tip">💡 Tuần cuối trước thi: Cambridge nhắc không học thêm nội dung mới. Tự tin với những gì đã học là chiến lược tốt nhất.</div>
        </div>

      </div>
    </div><!-- end ph4 -->

  </div><!-- end weekly view -->

</div><!-- end page -->

<script>
function switchTab(tab) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + tab).classList.add('active');
  event.target.classList.add('active');
}

function switchPhase(phase) {
  document.querySelectorAll('.weekly-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.phase-sel-btn').forEach(b => b.classList.remove('active', 'p1','p2','p3','p4'));
  document.getElementById(phase).classList.add('active');
  const btn = event.target;
  btn.classList.add('active');
  const cls = phase === 'ph1' ? 'p1' : phase === 'ph2' ? 'p2' : phase === 'ph3' ? 'p3' : 'p4';
  btn.classList.add(cls);
}
</script>
